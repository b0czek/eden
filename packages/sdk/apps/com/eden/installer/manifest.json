{
  "id": "com.eden.installer",
  "name": {
    "en": "Package Installer",
    "pl": "Instalator pakietów"
  },
  "version": "1.0.0",
  "description": "Install Eden packages",
  "build": {
    "command": "npm run build"
  },
  "icon": "icon.svg",
  "frontend": {
    "entry": "dist/index.html"
  },
  "window": {
    "mode": "window",
    "defaultSize": {
      "width": 600,
      "height": 500
    },
    "resizable": false,
    "movable": true,
    "injections": {
      "css": "full"
    }
  },
  "permissions": ["package/read", "fs/read"],
  "fileHandlers": [
    {
      "name": "Eden Packages",
      "extensions": ["edenite"]
    }
  ],
  "grants": [{ "scope": "preset", "preset": "package/manage" }],
  "hidden": true
}
