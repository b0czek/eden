{
  "id": "com.eden.editor",
  "name": {
    "en": "Text Editor",
    "pl": "Edytor Tekstu"
  },
  "version": "1.0.0",
  "description": "A Monaco-based text editor for editing files",
  "author": "Dariusz Majnert",
  "build": {
    "command": "npm run build"
  },
  "frontend": {
    "entry": "dist/index.html"
  },
  "window": {
    "mode": "both",
    "defaultSize": {
      "width": 900,
      "height": 700
    },
    "minSize": {
      "width": 400,
      "height": 300
    },
    "resizable": true,
    "movable": true
  },
  "permissions": ["fs/*"],
  "fileHandlers": [
    {
      "name": "Text Files",
      "extensions": ["txt", "md", "markdown", "log"],
      "mimeTypes": [
        "text/*",
        "application/javascript",
        "application/json",
        "application/xml",
        "application/x-empty"
      ]
    }
  ],
  "icon": "icon.svg"
}
